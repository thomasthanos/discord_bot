{
  "name": "discord-dashboard-bot",
  "version": "1.0.0",
  "description": "Discord bot with a synced Node.js dashboard",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "check": "node --check src/index.js && node --check src/dashboard/server.js && node --check src/database.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@snazzah/davey": "^0.1.10",
    "better-sqlite3": "^11.8.1",
    "discord-player": "^7.1.2",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5",
    "socket.io": "^4.8.1",
    "youtube-dl-exec": "^3.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
