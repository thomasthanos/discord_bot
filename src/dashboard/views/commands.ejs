<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Commands</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-page="commands" data-guild-id="<%= selectedGuildId || '' %>">
  <%- include('partials/sidebar') %>

  <main class="main">
    <div class="page-shell">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
        <div>
          <h1 class="page-title">Commands</h1>
          <p class="page-subtitle">Bot commands reference & execution logs</p>
        </div>
        <div class="view-toggle">
          <button class="view-btn active" onclick="showView('commands')" id="btnCommands">
            <svg viewBox="0 0 24 24"><path d="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z"/></svg>
            All Commands
          </button>
          <button class="view-btn" onclick="showView('logs')" id="btnLogs">
            <svg viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/></svg>
            Logs
          </button>
        </div>
      </div>

      <%
        const categories = { All: commands.length };
        commands.forEach((cmd) => {
          const key = cmd.category || 'General';
          categories[key] = (categories[key] || 0) + 1;
        });
      %>

      <!-- Commands View -->
      <div id="commandsView" class="commands-panel">
      <div class="tabs">
        <% Object.entries(categories).forEach(([cat, count]) => { %>
          <button class="tab <%= cat === 'All' ? 'active' : '' %>" onclick="filterCommands('<%= cat %>', this)">
            <%= cat %> <span class="count"><%= count %></span>
          </button>
        <% }); %>
      </div>

      <div class="command-list" id="commandList">
        <%
          const iconMap = {
            play: '<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>',
            skip: '<svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>',
            pause: '<svg viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>',
            queue: '<svg viewBox="0 0 24 24"><path d="M15 6H3v2h12V6zm0 4H3v2h12v-2zM3 16h8v-2H3v2zM17 6v8.18c-.31-.11-.65-.18-1-.18-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3V8h3V6h-5z"/></svg>',
            nowplaying: '<svg viewBox="0 0 24 24"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>',
            volume: '<svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>',
            stop: '<svg viewBox="0 0 24 24"><path d="M7 7h10v10H7z"/></svg>',
            shuffle: '<svg viewBox="0 0 24 24"><path d="M10.59 9.17L5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41l-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>',
            ban: '<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM4 12c0-4.42 3.58-8 8-8 1.85 0 3.55.63 4.9 1.69L5.69 16.9C4.63 15.55 4 13.85 4 12zm8 8c-1.85 0-3.55-.63-4.9-1.69L18.31 7.1C19.37 8.45 20 10.15 20 12c0 4.42-3.58 8-8 8z"/></svg>',
            kick: '<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 11H7v-2h10v2z"/></svg>',
            mute: '<svg viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>',
            warn: '<svg viewBox="0 0 24 24"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>',
            clear: '<svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>',
            help: '<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>',
            ping: '<svg viewBox="0 0 24 24"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>',
            serverinfo: '<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>',
            invites: '<svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V8l8 5 8-5v10zm-8-7L4 6h16l-8 5z"/></svg>',
            inviteleaderboard: '<svg viewBox="0 0 24 24"><path d="M7.5 21H2V9h5.5v12zm7.25-18h-5.5v18h5.5V3zM22 11h-5.5v10H22V11z"/></svg>'
          };
        %>
        <% commands.forEach(cmd => { %>
          <div class="command-item" data-category="<%= cmd.category %>">
            <div class="command-icon">
              <%- iconMap[cmd.name] || '<svg viewBox="0 0 24 24"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>' %>
            </div>
            <div class="command-info">
              <div class="command-name">
                /<%= cmd.name %>
                <% if (cmd.permissionLabel) { %>
                  <span class="command-permission">
                    <svg viewBox="0 0 24 24" width="10" height="10" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
                    <%= cmd.permissionLabel %>
                  </span>
                <% } %>
              </div>
              <div class="command-desc"><%= cmd.description %></div>
              <% if (cmd.options.length > 0) { %>
                <div class="command-usage">Usage: <code>/<%= cmd.name %> <%= cmd.options.map(o => o.required ? '<' + o.name + '>' : '[' + o.name + ']').join(' ') %></code></div>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
      </div>

      <!-- Logs View -->
      <div id="logsView" class="commands-panel" style="display: none;">
        <div class="tabs tabs-placeholder" aria-hidden="true">
          <% Object.entries(categories).forEach(([cat, count]) => { %>
            <span class="tab">
              <%= cat %> <span class="count"><%= count %></span>
            </span>
          <% }); %>
        </div>
        <div class="logs-list">
          <table class="log-table">
            <thead>
              <tr>
                <th>Command</th>
                <th>User</th>
                <th>Server</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody id="commandLogsBody">
              <% logs.slice(0, 50).forEach(log => { %>
                <tr>
                  <td class="cmd">/<%= log.command %></td>
                  <td class="user"><%= log.user_tag %></td>
                  <td><%= log.guild_name || 'DM' %></td>
                  <td><%= new Date(log.timestamp).toLocaleString() %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
          <div class="empty-state" id="commandLogsEmpty" style="<%= logs.length > 0 ? 'display: none;' : '' %>">No command logs yet.</div>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/nowplaying') %>

  <script>
    function animateInElements(elements) {
      elements.forEach((element, index) => {
        if (typeof element.animate !== 'function') return;
        element.animate(
          [
            { opacity: 0, transform: 'translateY(8px) scale(0.992)' },
            { opacity: 1, transform: 'translateY(0) scale(1)' }
          ],
          {
            duration: 240,
            delay: Math.min(index * 18, 160),
            easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
            fill: 'both'
          }
        );
      });
    }

    function filterCommands(category, btn) {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      const list = document.getElementById('commandList');
      const items = Array.from(document.querySelectorAll('.command-item'));

      if (list) list.classList.add('is-switching');

      setTimeout(() => {
        const visible = [];
        items.forEach((item) => {
          const shouldShow = category === 'All' || item.dataset.category === category;
          item.style.display = shouldShow ? '' : 'none';
          if (shouldShow) visible.push(item);
        });

        animateInElements(visible);
        if (list) list.classList.remove('is-switching');
      }, 120);
    }

    function showView(view) {
      const commandsView = document.getElementById('commandsView');
      const logsView = document.getElementById('logsView');
      const next = view === 'commands' ? commandsView : logsView;
      const prev = view === 'commands' ? logsView : commandsView;

      if (prev && prev.style.display !== 'none') {
        prev.style.opacity = '0';
        prev.style.transform = 'translateY(6px)';
      }

      setTimeout(() => {
        if (commandsView) commandsView.style.display = view === 'commands' ? '' : 'none';
        if (logsView) logsView.style.display = view === 'logs' ? '' : 'none';
        if (next) {
          next.style.opacity = '0';
          next.style.transform = 'translateY(6px)';
          requestAnimationFrame(() => {
            next.style.opacity = '1';
            next.style.transform = 'translateY(0)';
          });
        }
      }, 120);

      document.getElementById('btnCommands').classList.toggle('active', view === 'commands');
      document.getElementById('btnLogs').classList.toggle('active', view === 'logs');
    }
  </script>
  <%- include('partials/live-sync') %>
</body>
</html>
