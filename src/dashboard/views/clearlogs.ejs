<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clear Logs</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-page="clearlogs" data-guild-id="<%= selectedGuildId || '' %>">
  <%- include('partials/sidebar') %>

  <main class="main">
    <div class="page-shell">
      <h1 class="page-title">Clear Logs</h1>
      <p class="page-subtitle">Message deletion history with full transcripts</p>

      <table class="data-table" id="clearLogsTable" style="<%= logs.length === 0 ? 'display:none' : '' %>">
        <thead>
          <tr>
            <th>Moderator</th>
            <th>Channel</th>
            <th>Messages</th>
            <th>Server</th>
            <th>Date</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="clearLogsBody">
          <% logs.forEach(log => { %>
            <tr id="clear-log-row-<%= log.id %>">
              <td class="user-tag"><%= log.moderator_tag %></td>
              <td class="channel">#<%= log.channel_name %></td>
              <td><%= log.message_count %> items</td>
              <td class="server"><%= log.guild_name %></td>
              <td class="date"><%= new Date(log.timestamp).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' }) %></td>
              <td>
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                  <a href="/transcript/<%= log.id %><%= selectedGuildId ? ('?guildId=' + selectedGuildId) : '' %>" style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:8px;background:rgba(203,213,230,0.08);border:1px solid rgba(203,213,230,0.15);color:#cbd5e6;font-size:12px;font-weight:600;text-decoration:none;transition:all 0.15s;" onmouseover="this.style.background='rgba(203,213,230,0.16)'" onmouseout="this.style.background='rgba(203,213,230,0.08)'">
                    <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"/></svg>
                    Transcript
                  </a>
                  <button class="delete-log-btn" data-log-id="<%= log.id %>" title="Delete log" style="background:rgba(231,76,60,0.08);border:1px solid rgba(231,76,60,0.2);border-radius:8px;cursor:pointer;color:#e74c3c;padding:6px 8px;display:flex;align-items:center;transition:all 0.15s;" onmouseover="this.style.background='rgba(231,76,60,0.18)'" onmouseout="this.style.background='rgba(231,76,60,0.08)'">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                  </button>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <div class="empty-state" id="clearLogsEmpty" style="<%= logs.length > 0 ? 'display:none' : '' %>">No clear logs yet. Use /clear in a channel to see logs here.</div>
    </div>
  </main>

  <%- include('partials/nowplaying') %>
  <!-- Delete confirm modal -->
  <div id="deleteModal" style="display:none;position:fixed;inset:0;z-index:900;background:rgba(0,0,0,0.65);backdrop-filter:blur(6px);align-items:center;justify-content:center;">
    <div style="background:#1a1c20;border:1px solid rgba(255,255,255,0.12);border-radius:20px;padding:44px 52px;width:540px;box-shadow:0 24px 60px rgba(0,0,0,0.6);">
      <div style="display:flex;align-items:center;gap:18px;margin-bottom:20px;">
        <svg viewBox="0 0 24 24" width="34" height="34" fill="#e74c3c"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
        <span style="font-size:24px;font-weight:700;color:#f1f3f6;">Delete Log</span>
      </div>
      <p style="font-size:16px;color:#9aa2b0;margin-bottom:36px;line-height:1.6;">This will permanently delete the log entry and cannot be undone.</p>
      <div style="display:flex;gap:14px;justify-content:flex-end;">
        <button id="deleteModalCancel" style="padding:12px 28px;border-radius:10px;border:1px solid rgba(255,255,255,0.12);background:transparent;color:#9aa2b0;font-family:inherit;font-size:15px;cursor:pointer;">Cancel</button>
        <button id="deleteModalConfirm" style="padding:12px 28px;border-radius:10px;border:none;background:#e74c3c;color:#fff;font-family:inherit;font-size:15px;font-weight:700;cursor:pointer;">Delete</button>
      </div>
    </div>
  </div>

  <script>
    const deleteModal = document.getElementById('deleteModal');
    const deleteModalConfirm = document.getElementById('deleteModalConfirm');
    const deleteModalCancel = document.getElementById('deleteModalCancel');
    let pendingDeleteId = null;
    let pendingDeleteBtn = null;

    function showDeleteModal(id, btn) {
      pendingDeleteId = id;
      pendingDeleteBtn = btn;
      deleteModal.style.display = 'flex';
    }

    function hideDeleteModal() {
      deleteModal.style.display = 'none';
      pendingDeleteId = null;
      pendingDeleteBtn = null;
    }

    deleteModalCancel.addEventListener('click', hideDeleteModal);
    deleteModal.addEventListener('click', (e) => { if (e.target === deleteModal) hideDeleteModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hideDeleteModal(); });

    async function fetchAndRenderClearLogs() {
      const params = new URLSearchParams(window.location.search);
      const guildId = params.get('guildId') || '';
      const url = guildId ? `/api/clear-logs?guildId=${encodeURIComponent(guildId)}` : '/api/clear-logs';
      const res = await fetch(url);
      const logs = await res.json();
      const tbody = document.getElementById('clearLogsBody');
      const table = document.getElementById('clearLogsTable');
      const empty = document.getElementById('clearLogsEmpty');
      if (!tbody) return;
      if (!logs.length) {
        if (table) table.style.display = 'none';
        if (empty) empty.style.display = '';
        tbody.innerHTML = '';
        return;
      }
      if (table) table.style.display = '';
      if (empty) empty.style.display = 'none';
      tbody.innerHTML = logs.map((log) => {
        const date = new Date(log.timestamp).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
        const guildParam = guildId ? `?guildId=${encodeURIComponent(guildId)}` : '';
        const href = `/transcript/${log.id}${guildParam}`;
        return `<tr id="clear-log-row-${log.id}">
          <td class="user-tag">${log.moderator_tag}</td>
          <td class="channel">#${log.channel_name}</td>
          <td>${log.message_count} items</td>
          <td class="server">${log.guild_name}</td>
          <td class="date">${date}</td>
          <td><div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
            <a href="${href}" style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:8px;background:rgba(203,213,230,0.08);border:1px solid rgba(203,213,230,0.15);color:#cbd5e6;font-size:12px;font-weight:600;text-decoration:none;">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z"/></svg>Transcript</a>
            <button class="delete-log-btn" data-log-id="${log.id}" title="Delete log" style="background:rgba(231,76,60,0.08);border:1px solid rgba(231,76,60,0.2);border-radius:8px;cursor:pointer;color:#e74c3c;padding:6px 8px;display:flex;align-items:center;">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
            </button>
          </div></td>
        </tr>`;
      }).join('');
      bindDeleteButtons();
    }

    deleteModalConfirm.addEventListener('click', async () => {
      const id = pendingDeleteId;
      const btn = pendingDeleteBtn;
      hideDeleteModal();
      if (!id) return;
      if (btn) btn.disabled = true;
      try {
        const res = await fetch(`/api/clear-logs/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.ok) await fetchAndRenderClearLogs();
        else if (btn) btn.disabled = false;
      } catch { if (btn) btn.disabled = false; }
    });

    function bindDeleteButtons() {
      document.querySelectorAll('.delete-log-btn').forEach((btn) => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => showDeleteModal(btn.dataset.logId, btn));
      });
    }
    bindDeleteButtons();

    const observer = new MutationObserver(() => bindDeleteButtons());
    const tbody = document.getElementById('clearLogsBody');
    if (tbody) observer.observe(tbody, { childList: true });
  </script>
  <%- include('partials/live-sync') %>
</body>
</html>
