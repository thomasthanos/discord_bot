<%
  const gid = selectedGuildId || '';
  const withGuild = (path) => gid ? `${path}?guildId=${encodeURIComponent(gid)}` : path;
%>
<nav class="sidebar">
  <a href="<%= withGuild('/') %>" class="sidebar-logo <%= page === 'dashboard' ? 'active' : '' %>" title="Dashboard">
    <svg viewBox="0 0 24 24"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
  </a>
  <a href="<%= withGuild('/commands') %>" class="sidebar-item <%= page === 'commands' ? 'active' : '' %>" title="Commands">
    <svg viewBox="0 0 24 24"><path d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/></svg>
  </a>
  <a href="<%= withGuild('/clearlogs') %>" class="sidebar-item <%= page === 'clearlogs' ? 'active' : '' %>" title="Clear Logs">
    <svg viewBox="0 0 24 24"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
  </a>
  <a href="<%= withGuild('/invites') %>" class="sidebar-item <%= page === 'invites' ? 'active' : '' %>" title="Invite Tracker">
    <svg viewBox="0 0 24 24"><path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
  </a>
  <button type="button" id="serversToggleBtn" class="sidebar-item sidebar-item-toggle" title="Servers">
    <svg viewBox="0 0 24 24"><path d="M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5zm0 10a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4zm12 0a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2v-4z"/></svg>
  </button>

</nav>

<aside class="sidebar-extended" id="sidebarExtended">
  <div class="sidebar-extended-title">Servers</div>
  <div class="sidebar-extended-list">
    <% (guildOptions || []).forEach((g) => { %>
    <button
      type="button"
      class="guild-item <%= selectedGuildId === g.id ? 'active' : '' %>"
      data-guild-select="<%= g.id %>"
      data-guild-name="<%= g.name %>"
    >
        <% if (g.iconUrl) { %>
          <img src="<%= g.iconUrl %>" alt="<%= g.name %>" class="guild-icon">
        <% } else { %>
          <span class="guild-icon guild-icon-fallback"><%= (g.name || 'S')[0].toUpperCase() %></span>
        <% } %>
      </button>
    <% }) %>
  </div>
</aside>
